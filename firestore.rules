rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isActiveUser() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activo == true;
    }

    function hasPermission(permission) {
      return isActiveUser() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permisos[permission] == true;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if false;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if hasPermission('crearProductos');
      allow update: if hasPermission('editarProductos');
      allow delete: if hasPermission('eliminarProductos');
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if hasPermission('administrarCategorias');
    }

    match /subcategories/{subcategoryId} {
      allow read: if true;
      allow write: if hasPermission('administrarCategorias');
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if hasPermission('administrarMarcas');
    }

    match /quotes/{quoteId} {
      allow read: if true;
      allow create: if hasPermission('crearCotizaciones');
      allow update, delete: if hasPermission('verTodasCotizaciones');
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if hasPermission('configuracion');
    }

    match /invitations/{invitationId} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('administrarUsuarios');
    }

    match /activityLogs/{logId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser();
    }
  }
}
