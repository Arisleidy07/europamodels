rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: read/write own doc, or any authenticated user can read others
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Products: public read, authenticated write (permissions enforced in app)
    match /products/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Categories: public read, authenticated write
    match /categories/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Subcategories: public read, authenticated write
    match /subcategories/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Brands: public read, authenticated write
    match /brands/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Quotes: public read, authenticated write
    match /quotes/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Settings: public read, authenticated write
    match /settings/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Invitations
    match /invitations/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Activity logs
    match /activityLogs/{docId} {
      allow read, create: if request.auth != null;
    }
  }
}
