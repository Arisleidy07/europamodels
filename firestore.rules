rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      let u = userData();
      return u.activo == true && (u.isSuperAdmin == true || u.rol == 'administrador');
    }

    // Users: read own or if admin; write own profile or if admin
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuth() && isAdmin();
      allow update: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAuth() && isAdmin();
    }

    // Products, categories, brands, subcategories: public read, admin write
    match /products/{docId} {
      allow read: if true;
      allow create, update, delete: if isAuth() && isAdmin();
    }

    match /categories/{docId} {
      allow read: if true;
      allow create, update, delete: if isAuth() && isAdmin();
    }

    match /subcategories/{docId} {
      allow read: if true;
      allow create, update, delete: if isAuth() && isAdmin();
    }

    match /brands/{docId} {
      allow read: if true;
      allow create, update, delete: if isAuth() && isAdmin();
    }

    // Quotes: public read, authenticated create, admin manage
    match /quotes/{docId} {
      allow read: if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && isAdmin();
    }

    // Settings: public read, admin write
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAuth() && isAdmin();
    }

    // Invitations
    match /invitations/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && isAdmin();
    }

    // Activity logs
    match /activityLogs/{docId} {
      allow read, create: if isAuth();
    }
  }
}
