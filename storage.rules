rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isActiveAdmin() {
      let user = getUserData();
      return user.activo == true && (
        user.isSuperAdmin == true ||
        user.rol == 'administrador'
      );
    }

    // Product images — admins and users with product permissions
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && (
        isActiveAdmin() ||
        getUserData().permisos.productos.subirImagenes == true ||
        getUserData().permisos.productos.crear == true ||
        getUserData().permisos.productos.editar == true
      );
    }

    // Videos for home screen — only admins
    match /videos/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && isActiveAdmin();
    }

    // Company logos — only admins
    match /logos/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && isActiveAdmin();
    }

    // Profile photos — users can upload their own
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Default deny
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
