rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Product images — authenticated users (permissions enforced in app + Firestore rules)
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Videos for home screen — authenticated users (admin check in app)
    match /videos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Company logos — authenticated users (admin check in app)
    match /logos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Profile photos — users can upload their own
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Olfactory library images — authenticated users
    match /olfactory/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default deny
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
